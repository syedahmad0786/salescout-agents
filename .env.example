# --- All optional. With nothing set, SaleScout runs 100% locally on Ollama. ---

# Local model (default provider — install from https://ollama.com, then:
#   ollama pull llama3.1
OLLAMA_MODEL=llama3.1

# Optional: use Groq's free tier instead of local Ollama (much faster).
# Create a free key at https://console.groq.com — never commit it.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Crawl budget per company
SALESCOUT_MAX_PAGES=4
SALESCOUT_PAGE_CHARS=6000
